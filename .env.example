# Copy to apps/api/.env and adjust. Never commit .env.
# These are read by apps/api (see apps/api/src/config.js). Required vars are
# validated at boot — the API exits if any are missing/malformed. For production
# deployment, see DEPLOY.md (Railway + Neon + Cloudflare R2 + Resend).

# --- App ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
APP_ORIGIN=http://localhost:5173 # web app origin (CORS, email links, Socket.IO CORS)
API_ORIGIN=http://localhost:4000
# Prod (Option A — the API serves the built SPA, single origin): set both origins
# to the same deployed URL and flip NODE_ENV, e.g.
#   NODE_ENV=production
#   APP_ORIGIN=https://your-app.up.railway.app
#   API_ORIGIN=https://your-app.up.railway.app

# --- Database ---
# Dev: Postgres from docker compose (host port 5433, remapped to avoid clashing
# with a native postgres on 5432). Prod: Neon (or any managed Postgres). Use the
# POOLED connection string in prod. Schema lives in apps/api/prisma.
DATABASE_URL=postgresql://flotilla:flotilla@localhost:5433/flotilla?schema=public

# --- Session ---
# Prod: generate a strong secret — `openssl rand -hex 32` (>= 32 chars).
SESSION_SECRET=change-me-in-production-please-use-32+chars

# --- Object storage (MinIO dev / Cloudflare R2 prod) ---
# Dev: MinIO from docker compose. Prod: Cloudflare R2 (S3-compatible; free tier).
# R2 setup:
#   S3_ENDPOINT = https://<accountid>.r2.cloudflarestorage.com  (account-level S3 API URL)
#   S3_REGION   = auto
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = from an R2 API token (Object Read & Write)
#   S3_FORCE_PATH_STYLE = true
#   + add a bucket CORS rule allowing your app origin (browsers PUT uploads
#     directly to R2). Keep the bucket PRIVATE — reads use presigned GET URLs.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=flotilla-uploads
S3_ACCESS_KEY_ID=flotilla
S3_SECRET_ACCESS_KEY=flotilla123
S3_FORCE_PATH_STYLE=true

# --- Mail (SMTP) ---
# Dev: Mailpit on :1025 (docker compose). Prod: a transactional provider over SMTP.
# The app speaks SMTP (nodemailer) — NOT a provider's HTTP API. Resend example:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587            # STARTTLS (mailer.js hardcodes secure:false; 465 won't work)
#   SMTP_USER=resend
#   SMTP_PASS=<your re_... API key>
#   MAIL_FROM="Flotilla <noreply@your-verified-domain.com>"
# Mail is best-effort: signup still works without it, but verify/reset/invite/
# digest emails won't deliver until SMTP is configured.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Flotilla <noreply@flotilla.local>"

# --- Web push (Phase 6) ---
# Generate with: npx web-push generate-vapid-keys
# Optional in dev (push silently disabled if unset). Required for prod push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@flotilla.local

# --- Sentry (Phase 8, optional) ---
# Unset = no-op. Set to capture API + web errors in prod.
SENTRY_DSN=
